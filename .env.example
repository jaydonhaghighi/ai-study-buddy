# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# You can find these in your Firebase Console > Project Settings > General > Your apps

VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Local ML inference API for webcam focus tracking
VITE_INFERENCE_API_BASE_URL=http://localhost:8001
# Crop around detected face before uploading frames (recommended with current training data)
VITE_INFERENCE_FACE_CROP=1
# Mirror webcam input before upload (recommended with current training data orientation)
VITE_INFERENCE_MIRROR_INPUT=1

# OpenAI Configuration (set as a Functions secret for backend chat)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# Optional: default chat model for Cloud Functions
OPENAI_MODEL=gpt-4o-mini
# Optional: comma-separated allow-list accepted by /chat and /studyGenerate
OPENAI_ALLOWED_MODELS=gpt-4o-mini,gpt-4o,gpt-4.1-nano,gpt-4.1-mini,gpt-4.1,gpt-5-nano,gpt-5-mini,gpt-5,gpt-5.1,gpt-5.2,gpt-5.4
# Optional: model choices shown in the frontend settings menu
VITE_OPENAI_CHAT_MODELS=gpt-4o-mini,gpt-4o,gpt-4.1-nano,gpt-4.1-mini,gpt-4.1,gpt-5-nano,gpt-5-mini,gpt-5,gpt-5.1,gpt-5.2,gpt-5.4
# Optional: override model used for image OCR during material indexing
OPENAI_OCR_MODEL=gpt-4o-mini
