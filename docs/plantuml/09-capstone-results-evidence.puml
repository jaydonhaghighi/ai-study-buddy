@startuml
title AI Study Buddy - Capstone Results Evidence Layout

skinparam backgroundColor #FAFCFF
skinparam shadowing false
skinparam ArrowColor #3B5BDB
skinparam defaultFontName Arial
skinparam roundCorner 10
skinparam componentStyle rectangle
skinparam component {
  BorderColor #5B7CFA
  FontColor #1C2B4A
  BackgroundColor #EAF2FF
}

artifact "ml/artifacts/mlflow/" as SRC_MLFLOW #F3E8FF
artifact "ml/artifacts/reports/loso_aggregate.json" as SRC_LOSO #EAF2FF
artifact "ml/artifacts/reports/*confusion*" as SRC_CM #FFF7DB
database "focusSummaries\n(Firestore)" as SRC_SUM #E6F7EA

rectangle "Professor-Facing Results Section" #F4F8FF {
  component "A) LOSO Fold Performance\n- Macro-F1 mean/std\n- Per-fold comparison" as PANEL_A #EAF2FF
  component "B) Confusion Matrix\n- Class-wise error profile" as PANEL_B #FFF7DB
  component "C) Temporal Logic Impact\n- Raw vs smoothed labels\n- Transition stability" as PANEL_C #E6F7EA
  component "D) Session Analytics Snapshot\n- Focus %\n- Distracted seconds\n- Trend by session" as PANEL_D #F3E8FF
}

SRC_MLFLOW --> PANEL_A
SRC_LOSO --> PANEL_A
SRC_CM --> PANEL_B
SRC_LOSO --> PANEL_C
SRC_SUM --> PANEL_D

PANEL_A --> PANEL_D : Connect model quality to user outcomes

@enduml
