@startuml
title AI Study Buddy - Deployment Topology (Local Dev + Cloud Backend)

skinparam backgroundColor #FAFCFF
skinparam shadowing false
skinparam ArrowColor #3B5BDB
skinparam defaultFontName Arial
skinparam roundCorner 10
skinparam node {
  BorderColor #5B7CFA
  FontColor #1C2B4A
  BackgroundColor #EAF2FF
}

node "Developer Laptop" as LAPTOP #EAF2FF {
  node "Browser\nhttp://localhost:5173" as BROWSER #EAF2FF

  node "Docker Engine" as DOCKER #E6F7EA {
    node "Inference API Container\nhttp://localhost:8001" as INF #DDF3E3
    node "MLflow UI Container\nhttp://localhost:5001" as MLFLOW #DDF3E3
    artifact "best_model.keras" as MODEL #DDF3E3
  }
}

cloud "Firebase Cloud (GCP)" as FIREBASE #FFF6EA {
  node "Cloud Functions\n/chat, /focus/start, /focus/stop" as FN #FFEED7
  database "Firestore" as DB #FFF0DA
  node "Firebase Auth" as AUTH #FFEED7
}

cloud "OpenAI API" as OPENAI #F3E8FF {
  node "LLM Endpoint" as LLM #F3E8FF
}

BROWSER --> AUTH : auth via Firebase SDK
BROWSER --> FN : HTTPS calls
BROWSER --> INF : frame inference requests

FN --> DB : read/write app + session data
FN --> LLM : prompt + stream response

INF --> MODEL : load model for inference
BROWSER --> MLFLOW : optional experiment review

@enduml
