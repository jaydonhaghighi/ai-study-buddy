@startuml
title AI Study Buddy - Firestore Data Model (Conceptual)
hide methods
hide circle

skinparam backgroundColor #FAFCFF
skinparam shadowing false
skinparam ArrowColor #3B5BDB
skinparam defaultFontName Arial
skinparam roundCorner 10
skinparam class {
  BorderColor #5B7CFA
  FontColor #1C2B4A
  BackgroundColor #EAF2FF
}

class "Firebase Auth User\n<<external>>" as AuthUser #FFF4E0 {
  +uid: string
  +email: string
}

class "courses\n<<collection>>" as Course #EAF2FF {
  +id: string
  +userId: string
  +name: string
  +createdAt: timestamp
}

class "sessions\n<<collection>>" as Session #EAF2FF {
  +id: string
  +courseId: string
  +userId: string
  +name: string
  +createdAt: timestamp
}

class "chats\n<<collection>>" as Chat #EAF2FF {
  +id: string
  +sessionId: string
  +userId: string
  +name: string
  +updatedAt: timestamp
}

class "messages\n<<collection>>" as Message #EAF2FF {
  +id: string
  +chatId: string
  +role: user|assistant
  +content: string
  +createdAt: timestamp
}

class "focusSessions\n<<collection>>" as FocusSession #E6F7EA {
  +id: string
  +userId: string
  +courseId?: string
  +sessionId?: string
  +status: active|ended
  +startedAt: timestamp
  +endedAt?: timestamp
}

class "focusSummaries\n<<collection>>" as FocusSummary #E6F7EA {
  +id: string
  +userId: string
  +focusSessionId: string
  +focusPercent: number
  +distractedSeconds: number
  +timeline: array
}

class "genkit_sessions\n<<collection>>" as GenkitSession #F3E8FF {
  +id: string (sessionId)
  +state: object
  +threads.main: array
}

AuthUser "1" --> "0..*" Course : owns
Course "1" --> "0..*" Session : contains
Session "1" --> "0..*" Chat : contains
Chat "1" --> "0..*" Message : contains

Session "1" --> "0..*" FocusSession : study focus runs
FocusSession "1" --> "0..1" FocusSummary : summarized by
Chat "1" .. "1" GenkitSession : shares sessionId

note right of FocusSummary
Summary docs are saved after tracker stop
and feed dashboard analytics.
end note

@enduml
