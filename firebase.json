{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/health",
        "run": {
          "serviceId": "studybuddy-inference",
          "region": "us-central1"
        }
      },
      {
        "source": "/model-info",
        "run": {
          "serviceId": "studybuddy-inference",
          "region": "us-central1"
        }
      },
      {
        "source": "/predict",
        "run": {
          "serviceId": "studybuddy-inference",
          "region": "us-central1"
        }
      },
      {
        "source": "/session{,/**}",
        "run": {
          "serviceId": "studybuddy-inference",
          "region": "us-central1"
        }
      },
      {
        "source": "/ws/session{,/**}",
        "run": {
          "serviceId": "studybuddy-inference",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
