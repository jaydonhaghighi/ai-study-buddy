rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && userId is string && request.auth.uid == userId;
    }

    function isOwnerCreate() {
      return isOwner(request.resource.data.userId);
    }

    function isOwnerRead() {
      return isOwner(resource.data.userId);
    }

    function isOwnerUpdate() {
      return isOwner(resource.data.userId) &&
        request.resource.data.userId == resource.data.userId;
    }

    match /courses/{courseId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    match /sessions/{sessionId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    match /chats/{chatId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    match /messages/{messageId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    // Created/updated by backend functions; readable by owner for active-session UI.
    match /focusSessions/{focusSessionId} {
      allow read: if isOwnerRead();
      allow create, update, delete: if false;
    }

    // Frontend writes local summary details after tracker stop; owner-scoped.
    match /focusSummaries/{focusSummaryId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    // Backend-managed progress profile for streaks, levels, and badges.
    match /gamificationProfiles/{profileId} {
      allow read: if isSignedIn() && request.auth.uid == profileId;
      allow create, update, delete: if false;
    }

    // Backend-managed daily progress aggregates.
    match /gamificationDailyStats/{dailyId} {
      allow read: if isOwnerRead();
      allow create, update, delete: if false;
    }

    // Backend-managed weekly progress aggregates.
    match /gamificationWeeklyStats/{weeklyId} {
      allow read: if isOwnerRead();
      allow create, update, delete: if false;
    }

    // Immutable backend ledger for idempotent session awards.
    match /gamificationSessionAwards/{awardId} {
      allow read: if isOwnerRead();
      allow create, update, delete: if false;
    }

    match /courseMaterials/{materialId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    match /studySets/{studySetId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    match /flashcardReviews/{reviewId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    // Retrieval index is backend-only; never exposed directly to clients.
    match /material_chunks/{chunkId} {
      allow read, write: if false;
    }

    // Backend-only Genkit session persistence.
    match /genkit_sessions/{sessionId} {
      allow read, write: if false;
    }

    // Legacy/testing collection retained as owner-scoped instead of open access.
    match /data/{documentId} {
      allow read: if isOwnerRead();
      allow create: if isOwnerCreate();
      allow update: if isOwnerUpdate();
      allow delete: if isOwnerRead();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
